# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
DB_NAME=AmiyoGo

# Redis Configuration (Optional - app works without it)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
BULK_UPLOAD_USE_REDIS=false
BULK_UPLOAD_CONCURRENCY=2

# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="your_private_key"

# Email Configuration (Optional)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_login_email
SMTP_PASS=your_brevo_smtp_key
BREVO_SMTP_USER=your_brevo_login_email
BREVO_SMTP_KEY=your_brevo_smtp_key
EMAIL_FROM=noreply@amiyo-go.com
API_PUBLIC_URL=http://localhost:5000

# Push Notifications
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@amiyo-go.com

# Courier Providers (optional; leave blank for manual courier workflow)
# Put real values only in Server/.env or deployment secrets, never in source control.
COURIER_API_MODE=manual
COURIER_API_TIMEOUT_MS=12000
REDX_API_TOKEN=
REDX_API_BASE_URL=https://openapi.redx.com.bd/v1.0.0-beta
REDX_CREATE_PARCEL_PATH=/parcel
REDX_AUTH_HEADER=API-ACCESS-TOKEN
REDX_TRACKING_URL_PATTERN=
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=
STEADFAST_API_BASE_URL=https://portal.packzy.com/api/v1
STEADFAST_CREATE_ORDER_PATH=/create_order
STEADFAST_TRACKING_URL_PATTERN=

# Supabase Storage (optional; local uploads are used when blank)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=amiyo-go
IMAGE_MAX_WIDTH=1600

# Security
METRICS_KEY=your_secret_metrics_key
API_RATE_LIMIT_MAX=2000
API_RATE_LIMIT_WINDOW_MS=900000

# Logging
LOG_LEVEL=info

# Payment Gateways (Future Implementation)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
BKASH_APP_KEY=
BKASH_APP_SECRET=
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_KEY=
