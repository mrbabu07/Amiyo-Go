# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
MONGODB_URI=mongodb://localhost:27017
# Must match the database that contains products/orders.
DB_NAME=BazarBD

# Redis Configuration (recommended for queued delivery dispatch; inline fallback works without Redis)
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
BULK_UPLOAD_USE_REDIS=false
BULK_UPLOAD_CONCURRENCY=2

# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
# Optional: fixes Node/MongoDB SRV DNS failures on networks that refuse default DNS lookups
NODE_DNS_SERVERS=1.1.1.1,8.8.8.8

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="your_private_key"

# Email Configuration (Optional)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_login_email
SMTP_PASS=your_brevo_smtp_key
BREVO_SMTP_USER=your_brevo_login_email
BREVO_SMTP_KEY=your_brevo_smtp_key
EMAIL_FROM=noreply@amiyo-go.com
APP_EMAIL=support@amiyo-go.com
API_PUBLIC_URL=http://localhost:5000

# Push Notifications
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@amiyo-go.com
VAPID_EMAIL=mailto:admin@amiyo-go.com

# Courier Providers (optional; leave blank for manual courier workflow)
# Put real values only in Server/.env or deployment secrets, never in source control.
COURIER_API_MODE=manual
COURIER_API_TIMEOUT_MS=12000
REDX_API_TOKEN=
REDX_API_BASE_URL=https://openapi.redx.com.bd/v1.0.0-beta
REDX_CREATE_PARCEL_PATH=/parcel
REDX_AUTH_HEADER=API-ACCESS-TOKEN
REDX_TRACKING_URL_PATTERN=
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=
STEADFAST_API_BASE_URL=https://portal.packzy.com/api/v1
STEADFAST_CREATE_ORDER_PATH=/create_order
STEADFAST_TRACKING_URL_PATTERN=

# Amiyo Delivery app integration (optional; one marketplace order becomes one delivery order)
AMIYO_DELIVERY_API_URL=https://amiyo-delivery-server.vercel.app
AMIYO_DELIVERY_CLIENT_URL=https://amiyo-delivery-client.vercel.app
AMIYO_DELIVERY_INTEGRATION_TOKEN=
AMIYO_DELIVERY_WEBHOOK_SECRET=
AMIYO_DELIVERY_CALLBACK_API_SECRET=
AMIYO_DELIVERY_CALLBACK_SECRET=
# Compatibility aliases used by Amiyo-Go service authentication/callbacks
AMIYO_GO_API_SECRET=
AMIYO_GO_CALLBACK_SECRET=
AMIYO_INTEGRATION_TOKEN=
AMIYO_WEBHOOK_SECRET=
AMIYO_DELIVERY_TIMEOUT_MS=12000
AMIYO_DELIVERY_MAX_RETRIES=3
AMIYO_DELIVERY_RETRY_DELAY_MS=400
AMIYO_DELIVERY_CALLBACK_TOLERANCE_SECONDS=300
AMIYO_DELIVERY_REQUIRED=false
DELIVERY_DISPATCH_USE_REDIS=true
DELIVERY_DISPATCH_INLINE_FALLBACK=true
# Auto means serverless deploys process ready-to-ship dispatch inside the API request.
# Set false only when a separate long-running `npm run worker:delivery` process is deployed.
DELIVERY_DISPATCH_API_INLINE=
DELIVERY_DISPATCH_CONCURRENCY=4
DELIVERY_DISPATCH_ATTEMPTS=8
DELIVERY_DISPATCH_BACKOFF_MS=1000
DELIVERY_DISPATCH_REDIS_PING_TIMEOUT_MS=750
DELIVERY_DISPATCH_STALE_PROCESSING_MS=300000

# Image storage (ImgBB/Cloudinary/Supabase optional; local uploads are only for development)
IMGBB_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=amiyo-go
IMAGE_MAX_WIDTH=1600

# Security
METRICS_KEY=your_secret_metrics_key
API_RATE_LIMIT_MAX=2000
API_RATE_LIMIT_WINDOW_MS=900000
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRE=30d

# Logging
LOG_LEVEL=info

# Payment Gateways (Future Implementation)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_KEY=
NAGAD_MERCHANT_NUMBER=
NAGAD_PUBLIC_KEY=
NAGAD_PRIVATE_KEY=
NAGAD_BASE_URL=https://sandbox.nagad.com.bd
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_BASE_URL=https://sandbox.sslcommerz.com

# Brevo transactional email API (optional; SMTP above still works)
BREVO_API_KEY=
BREVO_API_URL=
BREVO_SENDER_EMAIL=noreply@amiyo-go.com
BREVO_SENDER_NAME=Amiyo-Go

# SMS providers (optional; mock mode when blank)
SSL_WIRELESS_API_TOKEN=
SSL_WIRELESS_SID=
SSL_WIRELESS_BASE_URL=https://sms.sslwireless.com
SSL_WIRELESS_SEND_PATH=/api/v3/send-sms
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_BASE_URL=

# Cloudinary upload provider (optional; ImgBB/Supabase/local fallback)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
SUPABASE_SERVICE_KEY=

# Delivery workflow knobs
DELIVERY_OTP_EXPIRE_MINUTES=10
DELIVERY_MAX_ATTEMPTS=3
DELIVERY_AUTO_ASSIGN=false
SUPPORT_PHONE=

# App metadata
ADMIN_EMAIL=admin@amiyo-go.com
SUPPORT_EMAIL=support@amiyo-go.com
APP_NAME=Amiyo-Go
APP_URL=http://localhost:5173
API_URL=http://localhost:5000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
OTP_EXPIRE_MINUTES=5
OTP_LENGTH=6
