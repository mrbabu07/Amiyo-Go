# SERVER
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
API_PUBLIC_URL=http://localhost:5000
NODE_DNS_SERVERS=1.1.1.1,8.8.8.8

# DATABASE
# Current app code uses MONGO_URI. MONGODB_URI is supported by the new service validator.
MONGO_URI=mongodb://localhost:27017/amiyo-go
MONGODB_URI=mongodb://localhost:27017/amiyo-go
DB_NAME=AmiyoGo
MONGO_BACKUP_DIR=./backups
MONGO_BACKUP_DRY_RUN=true
MONGODUMP_BIN=mongodump

# FIREBASE ADMIN
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="your_private_key"

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRE=30d

# REDIS / QUEUES
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=
REDIS_ENABLED=true
BULK_UPLOAD_USE_REDIS=false

# BKASH
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta

# NAGAD
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_NUMBER=
NAGAD_PUBLIC_KEY=
NAGAD_PRIVATE_KEY=
NAGAD_BASE_URL=https://sandbox.nagad.com.bd

# SSLCOMMERZ
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_BASE_URL=https://sandbox.sslcommerz.com

# STRIPE
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# BREVO EMAIL
BREVO_API_KEY=
BREVO_API_URL=
BREVO_SENDER_EMAIL=noreply@amiyo-go.com
BREVO_SENDER_NAME=Amiyo-Go

# SMTP FALLBACK
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@amiyo-go.com

# SSL WIRELESS SMS
SSL_WIRELESS_API_TOKEN=
SSL_WIRELESS_SID=
SSL_WIRELESS_BASE_URL=https://sms.sslwireless.com
SSL_WIRELESS_SEND_PATH=/api/v3/send-sms

# TWILIO SMS FALLBACK
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_BASE_URL=

# CLOUDINARY
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SUPABASE STORAGE FALLBACK
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=amiyo-go

# WEB PUSH VAPID
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@amiyo-go.com
VAPID_SUBJECT=mailto:admin@amiyo-go.com

# COURIER PROVIDERS
COURIER_API_MODE=manual
COURIER_API_TIMEOUT_MS=12000
REDX_API_TOKEN=
REDX_API_BASE_URL=https://openapi.redx.com.bd/v1.0.0-beta
REDX_CREATE_PARCEL_PATH=/parcel
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=
STEADFAST_API_BASE_URL=https://portal.packzy.com/api/v1
STEADFAST_CREATE_ORDER_PATH=/create_order

# AMIYO DELIVERY APP INTEGRATION
AMIYO_DELIVERY_API_URL=http://localhost:5001
AMIYO_DELIVERY_CLIENT_URL=http://localhost:3000
AMIYO_DELIVERY_INTEGRATION_TOKEN=
AMIYO_DELIVERY_WEBHOOK_SECRET=
AMIYO_DELIVERY_CALLBACK_API_SECRET=
AMIYO_DELIVERY_CALLBACK_SECRET=
AMIYO_DELIVERY_TIMEOUT_MS=12000
AMIYO_DELIVERY_MAX_RETRIES=3
AMIYO_DELIVERY_RETRY_DELAY_MS=400
AMIYO_DELIVERY_CALLBACK_TOLERANCE_SECONDS=300
AMIYO_DELIVERY_REQUIRED=false

# DELIVERY
DELIVERY_OTP_EXPIRE_MINUTES=10
DELIVERY_MAX_ATTEMPTS=3
DELIVERY_AUTO_ASSIGN=false
SUPPORT_PHONE=

# APP
ADMIN_EMAIL=admin@amiyo-go.com
SUPPORT_EMAIL=support@amiyo-go.com
APP_NAME=Amiyo-Go
APP_URL=http://localhost:5173
API_URL=http://localhost:5000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
OTP_EXPIRE_MINUTES=5
OTP_LENGTH=6
